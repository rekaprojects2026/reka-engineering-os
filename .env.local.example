# Copy to .env.local and fill in real values (never commit .env.local).

# Supabase (existing)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare R2 — S3-compatible API
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional: public bucket or CDN base URL (no trailing slash required). Leave empty for private-only + presigned GET.
R2_PUBLIC_URL=

# EngDocs Document App — archive inbox integration (on project close → R2 snapshot notify)
# ENGDOCS_APP_URL=http://localhost:3001
# NEXT_PUBLIC_ENGDOCS_APP_URL=http://localhost:3001
# (Public URL used by OS notification bell for links to EngDocs; can match ENGDOCS_APP_URL.)
# ENGDOCS_INTERNAL_SECRET=<same as INTERNAL_API_SECRET in EngDocs .env.local>
